# Bright Data (Stage 2)
# SERP API: one account API key + SERP zone name (free tier includes SERP credits).
BRIGHT_DATA_API_KEY=YOUR_BRIGHT_DATA_API_KEY_HERE
BRIGHT_DATA_SERP_ZONE=your_serp_zone_name

# Browser API (from wss://...@brd.superproxy.io:9222)
# Option A — full username from dashboard:
BRIGHT_DATA_BROWSER_USERNAME=brd-customer-hl_XXXXX-zone-your_browser_zone_name
BRIGHT_DATA_BROWSER_PASSWORD=YOUR_BRIGHT_DATA_BROWSER_PASSWORD_HERE

# Option B — auto-build username (used when BROWSER_USERNAME is unset):
BRIGHT_DATA_CUSTOMER_ID=hl_XXXXX
BRIGHT_DATA_BROWSER_ZONE=your_browser_zone_name

# Optional overrides
# BRIGHT_DATA_SERP_API_KEY=YOUR_BRIGHT_DATA_SERP_API_KEY_HERE
# BRIGHT_DATA_BROWSER_CDP_HOST=brd.superproxy.io:9222

# Daytona (Stage 3 + optional deploy)
DAYTONA_API_KEY=YOUR_DAYTONA_API_KEY_HERE

# LLM Stage 4 — default: TokenRouter (MiniMax v3)
LLM_PROVIDER=tokenrouter
TOKENROUTER_API_KEY=YOUR_TOKENROUTER_API_KEY_HERE
TOKENROUTER_MODEL=minimax-v3
# TOKENROUTER_ENVIRONMENT=production

# OpenRouter alternative (set LLM_PROVIDER=openrouter)
# OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
# OPENROUTER_MODEL=minimax-v3

# Direct Kimi / Moonshot API (set LLM_PROVIDER=kimi)
# KIMI_API_KEY=YOUR_KIMI_API_KEY_HERE
# KIMI_BASE_URL=https://api.moonshot.ai/v1
# KIMI_MODEL=moonshotai/Kimi-K2-Instruct

# Runtime
RUNS_DIR=./runs
AGENT_VERSION=0.1.0-hackathon

# Stage 1.5 entity resolution
CLARIFICATION_ENABLED=true
DISCOVERY_SERP_RESULTS=5

# Logging (file written under backend/logs/)
LOG_LEVEL=INFO
LOG_FILE=logs/pipeline.log
