{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/reputation-screening-report-rubric.schema.v1.json",
  "title": "Reputation Screening Report - Rubric Based",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_metadata",
    "subject",
    "screening_scope",
    "rubric_definition",
    "assessment",
    "risk_flags",
    "evidence",
    "analyst_checklist",
    "audit_trail"
  ],
  "properties": {
    "report_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report_id",
        "generated_at",
        "agent_version",
        "workflow_run_id",
        "data_sources"
      ],
      "properties": {
        "report_id": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "agent_version": { "type": "string" },
        "workflow_run_id": { "type": "string" },
        "data_sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "bright_data",
              "search_engine",
              "news_site",
              "company_website",
              "registry_site",
              "manual_input"
            ]
          }
        }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject_type", "primary_name"],
      "properties": {
        "subject_type": {
          "type": "string",
          "enum": ["individual", "organization"]
        },
        "primary_name": { "type": "string", "minLength": 1 },
        "aliases": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "country": { "type": ["string", "null"] },
        "industry": { "type": ["string", "null"] },
        "known_associations": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "input_notes": { "type": ["string", "null"] }
      }
    },
    "screening_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "jurisdictions",
        "languages",
        "lookback_period_years",
        "search_queries"
      ],
      "properties": {
        "jurisdictions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "languages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "lookback_period_years": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "search_queries": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "screening_limitations": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "rubric_definition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rubric_version",
        "component_scales",
        "support_band_rules",
        "case_risk_rules"
      ],
      "properties": {
        "rubric_version": { "type": "string" },
        "component_scales": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "entity_match",
            "source_tier",
            "adverse_severity",
            "recency",
            "jurisdiction_relevance",
            "corroboration",
            "case_linkage"
          ],
          "properties": {
            "entity_match": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              }
            },
            "source_tier": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["tier_1", "tier_2", "tier_3"]
              }
            },
            "adverse_severity": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["low", "medium", "high", "critical"]
              }
            },
            "recency": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["stale", "recent", "current"]
              }
            },
            "jurisdiction_relevance": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              }
            },
            "corroboration": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["none", "single_source", "multi_source"]
              }
            },
            "case_linkage": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              }
            }
          }
        },
        "support_band_rules": {
          "type": "array",
          "items": { "type": "string" }
        },
        "case_risk_rules": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overall_risk_level",
        "overall_summary",
        "coverage_assessment",
        "recommended_disposition",
        "determination_basis"
      ],
      "properties": {
        "overall_risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "overall_summary": {
          "type": "string",
          "minLength": 20
        },
        "coverage_assessment": {
          "type": "string",
          "enum": ["limited", "moderate", "broad"]
        },
        "coverage_notes": {
          "type": ["string", "null"]
        },
        "recommended_disposition": {
          "type": "string",
          "enum": [
            "no_material_concern",
            "manual_review_recommended",
            "escalate_to_compliance",
            "reject_or_hold"
          ]
        },
        "disposition_rationale": {
          "type": "string"
        },
        "determination_basis": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "method",
            "support_summary",
            "triggered_rules"
          ],
          "properties": {
            "method": {
              "type": "string",
              "enum": ["rule_based_v1"]
            },
            "support_summary": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "high_support_evidence_count",
                "medium_support_evidence_count",
                "low_support_evidence_count",
                "material_category_count",
                "official_or_tier_1_hits"
              ],
              "properties": {
                "high_support_evidence_count": { "type": "integer", "minimum": 0 },
                "medium_support_evidence_count": { "type": "integer", "minimum": 0 },
                "low_support_evidence_count": { "type": "integer", "minimum": 0 },
                "material_category_count": { "type": "integer", "minimum": 0 },
                "official_or_tier_1_hits": { "type": "integer", "minimum": 0 }
              }
            },
            "triggered_rules": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "flag_id",
          "category",
          "severity",
          "title",
          "description",
          "evidence_ids"
        ],
        "properties": {
          "flag_id": { "type": "string" },
          "category": {
            "type": "string",
            "enum": [
              "fraud",
              "financial_crime",
              "sanctions",
              "regulatory",
              "litigation",
              "corruption",
              "political_exposure",
              "reputational",
              "adverse_media",
              "ownership_opacity",
              "identity_mismatch",
              "other"
            ]
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["open", "mitigated", "dismissed", "needs_review"],
            "default": "open"
          },
          "evidence_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "analyst_note": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidence_id",
          "source_type",
          "source_name",
          "title",
          "url",
          "publication_date",
          "snippet",
          "risk_categories",
          "rubric_assessment",
          "support_band"
        ],
        "properties": {
          "evidence_id": { "type": "string" },
          "source_type": {
            "type": "string",
            "enum": [
              "news",
              "blog",
              "company_website",
              "registry",
              "court_record",
              "watchlist_reference",
              "other"
            ]
          },
          "source_name": { "type": "string" },
          "title": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "publication_date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "snippet": { "type": "string" },
          "language": { "type": ["string", "null"] },
          "risk_categories": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "fraud",
                "financial_crime",
                "sanctions",
                "regulatory",
                "litigation",
                "corruption",
                "political_exposure",
                "reputational",
                "adverse_media",
                "ownership_opacity",
                "identity_mismatch",
                "other"
              ]
            }
          },
          "rubric_assessment": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "entity_match",
              "source_tier",
              "adverse_severity",
              "recency",
              "jurisdiction_relevance",
              "corroboration",
              "case_linkage",
              "justification"
            ],
            "properties": {
              "entity_match": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              },
              "source_tier": {
                "type": "string",
                "enum": ["tier_1", "tier_2", "tier_3"]
              },
              "adverse_severity": {
                "type": "string",
                "enum": ["low", "medium", "high", "critical"]
              },
              "recency": {
                "type": "string",
                "enum": ["stale", "recent", "current"]
              },
              "jurisdiction_relevance": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              },
              "corroboration": {
                "type": "string",
                "enum": ["none", "single_source", "multi_source"]
              },
              "case_linkage": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              },
              "justification": {
                "type": "string"
              }
            }
          },
          "support_band": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "support_rule_triggered": {
            "type": ["string", "null"]
          },
          "is_adverse": { "type": "boolean" }
        }
      }
    },
    "analyst_checklist": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "item_id",
          "action",
          "priority",
          "reason"
        ],
        "properties": {
          "item_id": { "type": "string" },
          "action": { "type": "string" },
          "priority": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "reason": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "completed", "not_applicable"],
            "default": "pending"
          }
        }
      }
    },
    "audit_trail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_sources_reviewed",
        "total_evidence_items_retained",
        "false_positive_notes",
        "processing_notes"
      ],
      "properties": {
        "total_sources_reviewed": { "type": "integer", "minimum": 0 },
        "total_evidence_items_retained": { "type": "integer", "minimum": 0 },
        "false_positive_notes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "processing_notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}